{
  "name": "agix-platform",
  "private": true,
  "version": "0.2.2",
  "description": "Agix monorepo foundation for platform, delivery, and reusable scaffolding.",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": "10.8.1"
  },
  "scripts": {
    "dev": "turbo dev --filter=@agix/website",
    "dev:website": "pnpm --filter @agix/website dev",
    "build": "node ./scripts/monorepo-build.mjs",
    "build:turbo": "turbo build",
    "build:website": "pnpm --filter @agix/website build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test"
  },
  "devDependencies": {
    "turbo": "^2.0.14"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@google/generative-ai": "^0.24.1",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.3",
    "nodemailer": "^8.0.7",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.7"
  },
  "optionalDependencies": {
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "puppeteer-core": "^24.43.1"
  }
}
