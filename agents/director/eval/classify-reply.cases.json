      "expected": []
    },
    {
      "id": "model-error-misclassified-verb",
      "brief": "research-2026-06-01",
      "reply": "let's look closer at 2026-06-01.A2 before deciding",
      "raw_model_output": "{\"intents\":[{\"item_id\":\"2026-06-01.A2\",\"verb\":\"approve\",\"scope_hints\":\"\",\"raw_reply_excerpt\":\"let's look closer at 2026-06-01.A2\"}],\"unresolved\":[]}",
      "expected": [{ "item_id": "2026-06-01.A2", "verb": "dive" }],
      "note": "Recorded model misread 'look closer' (dive) as approve — a realistic misclassification that keeps macro-F1 honest."
    },
    {
      "id": "model-error-missed-intent",
      "brief": "research-2026-06-01",
      "reply": "YES 2026-06-01.A1 and dive into 2026-06-01.B2",
      "raw_model_output": "{\"intents\":[{\"item_id\":\"2026-06-01.A1\",\"verb\":\"approve\",\"scope_hints\":\"\",\"raw_reply_excerpt\":\"YES 2026-06-01.A1\"}],\"unresolved\":[]}",
      "expected": [
        { "item_id": "2026-06-01.A1", "verb": "approve" },
        { "item_id": "2026-06-01.B2", "verb": "dive" }
      ],
      "note": "Recorded model dropped the second intent — a realistic recall miss."
    },
    {
      "id": "guardrail-invented-id",
      "brief": "research-2026-06-01",
      "reply": "YES 2026-06-01.A1",
      "raw_model_output": "{\"intents\":[{\"item_id\":\"2026-06-01.A1\",\"verb\":\"approve\",\"scope_hints\":\"\",\"raw_reply_excerpt\":\"YES 2026-06-01.A1\"},{\"item_id\":\"2026-06-01.Z9\",\"verb\":\"approve\",\"scope_hints\":\"\",\"raw_reply_excerpt\":\"hallucinated\"}],\"unresolved\":[]}",
      "expected": [{ "item_id": "2026-06-01.A1", "verb": "approve" }],
      "guardrail": "Director must drop the invented ID Z9 (not in the brief) and keep the real one — 'never invent IDs', enforced on output."
    },
    {
      "id": "guardrail-malformed-json",
      "brief": "research-2026-06-01",
      "reply": "YES 2026-06-01.A1",
      "raw_model_output": "Sure! {intents: [{item_id: 2026-06-01.A1, verb: approve}]}",
      "expected": [],
      "guardrail": "Unquoted-key JSON must fail to parse → empty intents, never a crash."
    },
    {
      "id": "guardrail-no-json",
      "brief": "research-2026-06-01",
      "reply": "hmm",
      "raw_model_output": "I'm not sure what you'd like me to do here.",
      "expected": [],
      "guardrail": "No JSON object in the model output → empty intents."
    },
    {
      "id": "guardrail-unknown-verb",
      "brief": "research-2026-06-01",
      "reply": "build 2026-06-01.A1",
      "raw_model_output": "{\"intents\":[{\"item_id\":\"2026-06-01.A1\",\"verb\":\"build\",\"scope_hints\":\"\",\"raw_reply_excerpt\":\"build 2026-06-01.A1\"}],\"unresolved\":[]}",
      "expected": [],
      "guardrail": "Non-canonical verb 'build' is not in the supported set → dropped (the prompt mandates canonical verbs)."
    },
    {
      "id": "guardrail-malformed-id",
      "brief": "research-2026-06-01",
      "reply": "YES A1",
      "raw_model_output": "{\"intents\":[{\"item_id\":\"A1\",\"verb\":\"approve\",\"scope_hints\":\"\",\"raw_reply_excerpt\":\"YES A1\"}],\"unresolved\":[]}",
      "expected": [],
      "guardrail": "Un-qualified ID 'A1' is not well-formed (needs the date prefix) → dropped."
    }
